# De-identification service (browser calls it directly; runs in a Phala CVM)
NEXT_PUBLIC_DEID_SERVICE_URL=http://localhost:8000

# Epic on FHIR (patient import)
EPIC_CLIENT_ID=your-non-production-client-id
# EPIC_REDIRECT_URI=http://localhost:3000/callback
# EPIC_SCOPE=openid fhirUser launch/patient patient/*.rs

# Backend (accounts, roles, fields, literature)
DATABASE_URL=postgres://localhost:5432/yesyou
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_TRUST_HOST=true
# Google sign-in (optional; credentials sign-in works without it)
# AUTH_GOOGLE_ID=...
# AUTH_GOOGLE_SECRET=...

# Database integration tests skip when unset
# TEST_DATABASE_URL=postgres://localhost:5432/yesyou_test
