{
  "name": "yesyou-health",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.4.0",
  "type": "module",
  "description": "YesYou Health patient-authorized MyChart FHIR export",
  "engines": {
    "node": ">=20.9"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "fhir:markdown": "node --import tsx scripts/fhir-to-markdown.ts",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test tests/**/*.test.ts"
  },
  "dependencies": {
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
